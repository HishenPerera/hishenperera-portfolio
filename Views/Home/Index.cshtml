@{
    ViewData["Title"] = "Home";
}

@if (TempData["Success"] != null)
{
    <div class="toast-notification" id="toastSuccess">
        <span>@TempData["Success"]</span>
        <button type="button" class="close-toast" onclick="dismissToast()">&times;</button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="toast-notification toast-error" id="toastError">
        <span>@TempData["Error"]</span>
        <button type="button" class="close-toast" onclick="this.parentElement.remove()">&times;</button>
    </div>
}



<!-- HERO / PROFILE -->
<section id="profile" class="hero-section">
    <div class="container d-flex flex-column flex-lg-row-reverse align-items-center justify-content-center gap-5">

        <!-- Profile Image -->
        <div class="profile-image-wrapper reveal-hero" style="transition-delay: 0.1s;">
            <img src="/images/hishen.png" alt="Hishen Perera" class="profile-image" />
        </div>

        <!-- Profile Text -->
        <div class="profile-text text-center text-lg-start reveal-group">
            <h1 class="hero-title">
                Hi, I'm <span class="gradient-text">Hishen</span> đź‘‹
            </h1>

            <!-- HERO SUBTITLE -->
            <p class="hero-subtitle">
                I'm a <span class="typing-text" data-words='["Software Developer","SLIIT Undergraduate","Full-Stack Enthusiast",".NET Specialist","Modern Web Builder"]'></span>
            </p>

            <div class="mt-3">
                <a href="#projects" class="btn hero-btn btn-lg me-3">
                    View My Work
                </a>
            </div>
        </div>

    </div>
</section>

<!-- PROJECTS -->
<section id="projects" class="projects-section">
    <div class="container">

        <h2 class="section-title text-center mb-5 reveal-title">
            Featured Projects
        </h2>

        @if (!Model.Projects.Any())
        {
            <p class="text-center text-muted reveal">No projects added yet.</p>
        }
        else
        {
            @for (int i = 0; i < Model.Projects.Count; i++)
            {
                var project = Model.Projects[i];
                var isEven = i % 2 == 0;

                <div class="project-wide-card-wrapper @(isEven ? "image-left" : "image-right") reveal">
                    <a href="@project.ProjectLink" target="_blank" class="project-wide-card">
                        <div class="project-image">
                            <img src="@project.ProjectImg"
                                 alt="@project.ProjectName"
                                 onerror="this.src='/images/placeholder.png'" />
                        </div>

                        <div class="project-content">
                            <h3>@project.ProjectName</h3>
                            <p>Click to explore the project in detail</p>
                            <span class="view-link">View Project â†’</span>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</section>

