@model hishenperera_portfolio.Models.HomePageViewModel

@{
    ViewData["Title"] = "Home";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center mb-4">
        @TempData["Success"]
    </div>
}

<!-- HERO / PROFILE -->
<section id="profile" class="hero-section">
    <div class="container d-flex flex-column flex-lg-row-reverse align-items-center justify-content-center gap-5">
        
        <!-- Profile Image -->
        <div class="profile-image-wrapper">
            <img src="/images/hishen.png" alt="Hishen Perera" class="profile-image" />
        </div>

        <!-- Profile Text -->
        <div class="profile-text text-center text-lg-start">
            <h1 class="hero-title">
                Hi, I'm <span class="gradient-text">Hishen</span> 👋
            </h1>

            <!-- HERO SUBTITLE -->
            <p class="hero-subtitle">
                I'm a <span class="typing-text" data-words='["Software Developer","SLIIT Undergraduate","Full-Stack Enthusiast",".NET Specialist","Modern Web Builder"]'></span>
            </p>

            <div class="mt-3">
                <a href="#projects" class="btn hero-btn btn-lg me-3">
                    View My Work
                </a>
            </div>
        </div>

    </div>
</section>

<!-- PROJECTS -->
<section id="projects" class="projects-section">
    <div class="container">

        <h2 class="section-title text-center mb-5">
            Featured Projects
        </h2>

        @if (!Model.Projects.Any())
        {
            <p class="text-center text-muted">No projects added yet.</p>
        }
        else
        {
            @for (int i = 0; i < Model.Projects.Count; i++)
            {
                var project = Model.Projects[i];
                var isEven = i % 2 == 0;

                <div class="project-wide-card-wrapper @(isEven ? "image-left" : "image-right")">
                    <a href="@project.ProjectLink" target="_blank" class="project-wide-card">
                        <div class="project-image">
                            <img src="@project.ProjectImg"
                                 alt="@project.ProjectName"
                                 onerror="this.src='/images/placeholder.png'" />
                        </div>

                        <div class="project-content">
                            <h3>@project.ProjectName</h3>
                            <p>Click to explore the project in detail</p>
                            <span class="view-link">View Project →</span>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</section>

<!-- CONTACT -->
<section id="contact" class="contact-section">
    <div class="container">

        <h2 class="section-title text-center mb-5">
            Drop a Message
        </h2>
        <div class="row justify-content-center">
            <div class="col-lg-6">

                <form asp-action="Contact" method="post" class="contact-form">

                    <div class="mb-3">
                        <label class="form-label" for="Contact_Name">Your Name</label>
                        <input asp-for="Contact.Name" class="form-control" id="Contact_Name" required/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Contact_Email">Email Address</label>
                        <input asp-for="Contact.Email" class="form-control" id="Contact_Email" required/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="Contact_Message">Message</label>
                        <textarea asp-for="Contact.Message"
                                  class="form-control"
                                  id="Contact_Message"
                                  rows="5" required></textarea>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg">
                            Send Message
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</section>
