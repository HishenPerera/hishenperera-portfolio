@section Scripts {
<script>
    (function () {
        var targets = document.querySelectorAll('.reveal, .reveal-hero, .reveal-title, .reveal-group');
        if (!targets.length) return;

        // â”€â”€ Step 1: Kill transitions so elements already in-view on load
        //            snap into place silently (no animation on first visit).
        targets.forEach(function (el) {
            el.style.transition = 'none';
        });

        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                } else {
                    // Reverse: shrink back out when scrolled past going up
                    entry.target.classList.remove('in-view');
                }
            });
        }, {
            threshold: 0.12,
            rootMargin: '0px 0px -40px 0px'
        });

        targets.forEach(function (el) {
            observer.observe(el);
        });

        // â”€â”€ Step 2: Re-enable transitions after two paint frames.
        //            By then, initial in-view elements have already snapped
        //            to their visible state without animating.
        requestAnimationFrame(function () {
            requestAnimationFrame(function () {
                targets.forEach(function (el) {
                    el.style.transition = '';
                });
            });
        });
    })();

    // â”€â”€ Phone picker: combine country code + local number into hidden field â”€â”€
    (function () {
        var codeSelect  = document.getElementById('countryCodeSelect');
        var localInput  = document.getElementById('localPhone');
        var hiddenPhone = document.getElementById('Contact_Phone');
        var form        = localInput ? localInput.closest('form') : null;

        if (!codeSelect || !localInput || !hiddenPhone || !form) return;

        // Auto-format as Sri Lankan style: 77 XXX XXXX (works for any country)
        function formatLocal(raw) {
            var d = raw.replace(/\D/g, '').slice(0, 9); // max 9 raw digits
            if (d.length <= 2)  return d;
            if (d.length <= 5)  return d.slice(0,2) + ' ' + d.slice(2);
            return d.slice(0,2) + ' ' + d.slice(2,5) + ' ' + d.slice(5);
        }

        localInput.addEventListener('input', function () {
            var pos = this.selectionStart;
            var prev = this.value.length;
            this.value = formatLocal(this.value);
            // Restore caret roughly
            var diff = this.value.length - prev;
            this.setSelectionRange(pos + diff, pos + diff);
        });

        form.addEventListener('submit', function (e) {
            var code  = codeSelect.value;                        // e.g. "+94"
            var local = localInput.value.replace(/\D/g, '');    // digits only
            local = local.replace(/^0+/, '');                   // strip leading 0

            if (!local) {
                e.preventDefault();
                localInput.setCustomValidity('Please enter your phone number.');
                localInput.reportValidity();
                return;
            }

            localInput.setCustomValidity('');
            hiddenPhone.value = code + local;  // e.g. "+94712345678"
        });
    })();
</script>
}
